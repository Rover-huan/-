APP_ENV=local
PUBLIC_BASE_URL=http://127.0.0.1:8000
API_ROOT_PATH=
AUTO_CREATE_TABLES=true

OPENAI_API_KEY=replace-with-server-side-model-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_ATTEMPTS=5
OPENAI_BACKOFF_SECONDS=1
LLM_CIRCUIT_BREAKER_OPEN=false
LLM_DAILY_BUDGET_LIMIT=0

SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///./smartanalyst.db
REDIS_URL=redis://localhost:6379/0

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./storage
JOB_WORKSPACE_ROOT=./runs

S3_BUCKET=smartanalyst-prod
S3_REGION=oss-cn-hangzhou
S3_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
S3_ACCESS_KEY_ID=replace-with-oss-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-oss-secret-access-key
S3_SECURE=true
S3_ADDRESSING_STYLE=virtual

ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_COOKIE_NAME=smartanalyst_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

ARTIFACT_TTL_MINUTES=1440
MAX_UPLOAD_FILES=5
MAX_FILE_SIZE_BYTES=20971520
MAX_TOTAL_UPLOAD_BYTES=104857600
MAX_USER_ACTIVE_JOBS=2
MAX_GLOBAL_ACTIVE_JOBS=20
MAX_DAILY_JOBS_PER_USER=10
MAX_DAILY_UPLOAD_BYTES_PER_USER=262144000
REGISTER_RATE_LIMIT_PER_HOUR_IP=10
LOGIN_RATE_LIMIT_PER_15_MIN_IP=30
MAX_JOB_RUNTIME_SECONDS=1800

QUEUE_NAME=smartanalyst
ANALYSIS_QUEUE_NAME=analysis
RENDER_QUEUE_NAME=render
CELERY_SOFT_TIME_LIMIT=1800
CELERY_HARD_TIME_LIMIT=2100

RUNNER_MODE=subprocess
RUNNER_TIMEOUT_SECONDS=240
CHART_GENERATION_CONCURRENCY=2

ENABLE_AUTO_TOC=true
# Supported values: word_com, libreoffice, aspose, none
AUTO_TOC_BACKEND=word_com

DOWNLOAD_URL_EXPIRE_SECONDS=300
SSE_POLL_INTERVAL_SECONDS=2

ADMIN_API_TOKEN=
ENABLE_ADMIN_DEBUG=false
ADMIN_OWNER_EMAIL=owner@example.com
ADMIN_OWNER_INITIAL_PASSWORD=replace-with-owner-password
ADMIN_SESSION_COOKIE_NAME=smartanalyst_admin_session
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=720
PRESENCE_ONLINE_WINDOW_SECONDS=300
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

CAPTCHA_REQUIRED=false
CAPTCHA_PROVIDER=generic
CAPTCHA_VERIFY_URL=
CAPTCHA_SECRET_KEY=
CAPTCHA_BYPASS_TOKEN=

# Beta/local default: do not require email verification yet.
# Keep SMTP_* below for the future. After the /verify-email frontend page
# and SMTP delivery are ready, set EMAIL_VERIFICATION_REQUIRED=true.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
