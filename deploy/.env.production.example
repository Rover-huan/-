APP_ENV=production
PUBLIC_BASE_URL=https://your-domain.example
API_ROOT_PATH=/api
AUTO_CREATE_TABLES=false

OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_ATTEMPTS=5
OPENAI_BACKOFF_SECONDS=1
LLM_CIRCUIT_BREAKER_OPEN=false
LLM_DAILY_BUDGET_LIMIT=1000

# Optional final body-polish pass after draft report synthesis and before rendering.
# Keep disabled unless a server-side DeepSeek polish key is configured.
ENABLE_DEEPSEEK_POLISH=false
DEEPSEEK_POLISH_API_KEY=<DEEPSEEK_POLISH_API_KEY>
DEEPSEEK_POLISH_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_POLISH_MODEL=deepseek-v4-flash
DEEPSEEK_POLISH_TIMEOUT_SECONDS=180
DEEPSEEK_POLISH_MAX_INPUT_CHARS=120000

SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=<POSTGRES_DATABASE_URL>
REDIS_URL=redis://:password@tair-host:6379/0

STORAGE_BACKEND=s3
S3_BUCKET=smartanalyst-prod
S3_REGION=oss-cn-hangzhou
S3_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
S3_ACCESS_KEY_ID=replace-with-oss-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-oss-secret-access-key
S3_SECURE=true
S3_ADDRESSING_STYLE=virtual

LOCAL_STORAGE_ROOT=/app/storage
JOB_WORKSPACE_ROOT=/app/runs

ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_COOKIE_NAME=smartanalyst_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

ARTIFACT_TTL_MINUTES=1440
MAX_UPLOAD_FILES=5
MAX_FILE_SIZE_BYTES=20971520
MAX_TOTAL_UPLOAD_BYTES=104857600
MAX_USER_ACTIVE_JOBS=2
MAX_GLOBAL_ACTIVE_JOBS=20
MAX_DAILY_JOBS_PER_USER=10
MAX_DAILY_UPLOAD_BYTES_PER_USER=262144000
REGISTER_RATE_LIMIT_PER_HOUR_IP=10
LOGIN_RATE_LIMIT_PER_15_MIN_IP=30
MAX_JOB_RUNTIME_SECONDS=1800

QUEUE_NAME=smartanalyst
ANALYSIS_QUEUE_NAME=analysis
RENDER_QUEUE_NAME=render
CELERY_SOFT_TIME_LIMIT=1800
CELERY_HARD_TIME_LIMIT=2100

RUNNER_MODE=subprocess
RUNNER_TIMEOUT_SECONDS=240
CHART_GENERATION_CONCURRENCY=2

DOWNLOAD_URL_EXPIRE_SECONDS=300
SSE_POLL_INTERVAL_SECONDS=2

ADMIN_API_TOKEN=replace-with-admin-token
ENABLE_ADMIN_DEBUG=false
ADMIN_OWNER_EMAIL=owner@your-domain.example
ADMIN_OWNER_INITIAL_PASSWORD=replace-with-owner-password
ADMIN_SESSION_COOKIE_NAME=smartanalyst_admin_session
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=720
PRESENCE_ONLINE_WINDOW_SECONDS=300
CORS_ORIGINS=https://your-domain.example

CAPTCHA_REQUIRED=true
CAPTCHA_PROVIDER=aliyun
CAPTCHA_VERIFY_URL=https://your-captcha-verify-endpoint.example
CAPTCHA_SECRET_KEY=replace-with-captcha-secret
CAPTCHA_BYPASS_TOKEN=

# Beta first release: keep mandatory email verification disabled so users
# are not blocked before the /verify-email frontend page is completed.
# Keep SMTP_* below for future enablement; set this to true only after SMTP
# delivery and the verification page are ready.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@your-domain.example
SMTP_USE_TLS=true

VITE_CAPTCHA_ENABLED=true
VITE_EMAIL_VERIFICATION_ENABLED=false
ANALYSIS_WORKER_CONCURRENCY=2
RENDER_WORKER_CONCURRENCY=1
