# SmartAnalyst local zero-cost demo settings.
# Copy this file to .env.local-demo for private local overrides.
# Never commit .env.local-demo or real secrets.

APP_ENV=local
PUBLIC_BASE_URL=http://localhost:8080
API_ROOT_PATH=/api
AUTO_CREATE_TABLES=true

OPENAI_API_KEY=<OPENAI_API_KEY>
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_ATTEMPTS=3
OPENAI_BACKOFF_SECONDS=1
LLM_CIRCUIT_BREAKER_OPEN=false
LLM_DAILY_BUDGET_LIMIT=0

SECRET_KEY=replace-with-local-demo-random-secret
DATABASE_URL=sqlite:////app/data/smartanalyst.db
REDIS_URL=redis://redis:6379/0

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/app/storage
JOB_WORKSPACE_ROOT=/app/runs

ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_COOKIE_NAME=smartanalyst_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

ARTIFACT_TTL_MINUTES=1440
MAX_UPLOAD_FILES=5
MAX_FILE_SIZE_BYTES=1048576
MAX_TOTAL_UPLOAD_BYTES=5242880
MAX_USER_ACTIVE_JOBS=1
MAX_GLOBAL_ACTIVE_JOBS=1
MAX_DAILY_JOBS_PER_USER=5
MAX_DAILY_UPLOAD_BYTES_PER_USER=20971520
REGISTER_RATE_LIMIT_PER_HOUR_IP=20
LOGIN_RATE_LIMIT_PER_15_MIN_IP=30
MAX_JOB_RUNTIME_SECONDS=1800

QUEUE_NAME=smartanalyst
ANALYSIS_QUEUE_NAME=analysis
RENDER_QUEUE_NAME=render
CELERY_SOFT_TIME_LIMIT=1800
CELERY_HARD_TIME_LIMIT=2100

RUNNER_MODE=subprocess
RUNNER_TIMEOUT_SECONDS=240
CHART_GENERATION_CONCURRENCY=1

ENABLE_PDF_EXPORT=false
ENABLE_AUTO_TOC=false
AUTO_TOC_BACKEND=none

DOWNLOAD_URL_EXPIRE_SECONDS=300
SSE_POLL_INTERVAL_SECONDS=2

ADMIN_API_TOKEN=
ENABLE_ADMIN_DEBUG=false
ADMIN_OWNER_EMAIL=owner@example.com
ADMIN_OWNER_INITIAL_PASSWORD=replace-with-owner-password
ADMIN_SESSION_COOKIE_NAME=smartanalyst_admin_session
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=720
PRESENCE_ONLINE_WINDOW_SECONDS=300
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

CAPTCHA_REQUIRED=false
CAPTCHA_PROVIDER=generic
CAPTCHA_VERIFY_URL=
CAPTCHA_SECRET_KEY=
CAPTCHA_BYPASS_TOKEN=

EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

VITE_CAPTCHA_ENABLED=false
VITE_EMAIL_VERIFICATION_ENABLED=false
ANALYSIS_WORKER_CONCURRENCY=1
RENDER_WORKER_CONCURRENCY=1
LOCAL_DEMO_HTTP_PORT=8080
